# Telegram Bot Token
TELEGRAM_TOKEN=your_bot_token_here

# Интервал проверки билетов (в секундах)
CHECK_INTERVAL=60

# Уровень логирования: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Путь к основному лог-файлу
LOG_FILE=logs/bot.log

# Путь к файлу ошибок
ERROR_LOG_FILE=logs/error.log

# ============================================
# НАСТРОЙКИ АДМИН-ПАНЕЛИ
# ============================================

# Имя пользователя администратора
ADMIN_USERNAME=admin

# Пароль администратора (СМЕНите в production!)
ADMIN_PASSWORD=admin123

# Секретный ключ для сессий Flask (сгенерируйте уникальный!)
SECRET_KEY=change-this-to-random-string-in-production

# Хост и порт для запуска админ-панели
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
